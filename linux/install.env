# Optional settings for install.sh on Linux/BSD.
# Copy or edit this file; it is sourced automatically when present.
#
# DOTFILES_NO_SUDO=1
#   If set, the installer will not run sudo to install packages. zsh must
#   already be on PATH or the script exits with an error.
#
# DOTFILES_SKIP_OH_MY_ZSH=1
#   If set, Oh My Zsh is not installed; link ~/.zshrc only (you need ~/.oh-my-zsh yourself).
